# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# experiments/ holds generated/downloaded data and is not tracked, EXCEPT the
# per-benchmark manifest.toml files, which define each benchmark.
/experiments/*
!/experiments/data
/experiments/data/*
!/experiments/data/benchmarks
/experiments/data/benchmarks/*/*
!/experiments/data/benchmarks/*/manifest.toml

uv.lock
results/
.env

.DS_Store
.claude/
