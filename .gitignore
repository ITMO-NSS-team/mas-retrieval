# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# experiments/ holds content (systems + benchmarks). Adapter code under
# systems/ is tracked in full; benchmark dirs track only the committed recipe
# (manifest.toml + builder.py), while generated/downloaded data is ignored.
/experiments/*
!/experiments/benchmarks
!/experiments/systems
/experiments/benchmarks/*/*
!/experiments/benchmarks/*/manifest.toml
!/experiments/benchmarks/*/builder.py

uv.lock
results/
logs/
.env

.DS_Store
.claude/
