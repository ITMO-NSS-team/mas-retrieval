# LLM access used by the LLM-as-a-judge
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Benchmark preparation: GitHub token to fetch source files (e.g. FinanceBench PDFs).
GITHUB_TOKEN=

# --- Library settings ---
# MARLIB_LOG_LEVEL=INFO
#
# Retrieval MCP server (marlib.retriever.mcp_server). Normally set automatically
# by the retrieval adapters (fedotmas/automas) when they spawn the server;
# uncomment only to run/override it manually.
# RETCAP_EMBEDDER=BAAI/bge-m3
# RETCAP_RERANKER=BAAI/bge-reranker-v2-m3
# RETCAP_INDEX_PATH=experiments/benchmarks
# RETCAP_COLLECTION=financebench
# RETCAP_DOCIDS_FILE=          # path to append retrieved doc_ids (for context_recall)
