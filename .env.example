# LLM access used by the LLM-as-a-judge
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Model for the LLM-as-a-judge (llm_accuracy metric). Kept independent of the
# system-under-test backbone (--model) so scoring stays consistent across runs.
# Default: openai/gpt-4o-mini
# JUDGE_MODEL=openai/gpt-4o-mini

# Benchmark preparation: GitHub token to fetch source files (e.g. FinanceBench PDFs).
GITHUB_TOKEN=

# Disable pydantic plugins: the installed logfire (a pydantic entry-point plugin)
# imports a symbol removed in opentelemetry-sdk 1.41, spamming a harmless
# ImportError UserWarning on every pydantic-ai agent run. We don't use logfire.
PYDANTIC_DISABLE_PLUGINS=1

# --- Library settings ---
# MARLIB_LOG_LEVEL=INFO
#
# Retriever config (RetrieverSettings). The CLI exports these for the MCP server
# (marlib.mcp_server) it spawns; uncomment only to run the server manually.
# INDEX_PATH and COLLECTION are required (no default); the rest fall back to
# the BGE-M3 defaults / 20 / 10.
# MARLIB_INDEX_PATH=experiments/benchmarks
# MARLIB_COLLECTION=financebench
# MARLIB_EMBEDDER=BAAI/bge-m3
# MARLIB_RERANKER=BAAI/bge-reranker-v2-m3
# MARLIB_RETRIEVE_TOP_K=20
# MARLIB_RERANK_TOP_K=10
# MARLIB_DOCIDS_FILE=          # path to append retrieved doc_ids (for context_recall)
